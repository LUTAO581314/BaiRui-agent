HERMES_APP_NAME=hermes-runtime
HERMES_ENV=production
HERMES_HOST=127.0.0.1
HERMES_PORT=8787
HERMES_SAFE_MODE=true
HERMES_DATA_DIR=/opt/hermes-system/data
HERMES_LOG_DIR=/opt/hermes-system/logs
HERMES_OBSIDIAN_VAULT_DIR=/opt/hermes-system/obsidian-vault
HERMES_ENABLE_FEISHU_SMOKE=false
HERMES_SEARCH_MODE=external_project
HERMES_SEARCH_PROJECT=trendradar
HERMES_TRENDRADAR_BASE_URL=
HERMES_TRENDRADAR_MCP_COMMAND=
HERMES_SEARXNG_BASE_URL=

# Keep real secrets only in the server-side .env file. Never commit them.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
OPENAI_API_KEY=
