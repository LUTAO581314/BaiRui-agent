diff --git a/src/ui/brain-ui/app.js b/src/ui/brain-ui/app.js
--- a/src/ui/brain-ui/app.js
+++ b/src/ui/brain-ui/app.js
@@
+  // Phase 32: QQ personal scan bridge panel.
+  // Today it reports bridge_missing until NapCat or Lagrange is installed.
+  async function refreshQQPersonalStatus({ showMessage = false } = {}) {
+    const data = await fetch(`${API}/social/qq-personal/qr`).then(r => r.json())
+    // connected / qr_ready / bridge_missing states are rendered in the social panel.
+  }
+
+  qqPersonalRefreshBtn?.addEventListener("click", () => refreshQQPersonalStatus({ showMessage: true }));
+  qqPersonalConnectBtn?.addEventListener("click", async () => {
+    const resp = await fetch(`${API}/social/qq-personal/start`, { method: "POST" });
+    // HTTP 501 is shown as "bridge not installed" instead of pretending scan is ready.
+  });
+  qqPersonalLogoutBtn?.addEventListener("click", async () => {
+    await fetch(`${API}/social/qq-personal/logout`, { method: "POST" });
+  });
