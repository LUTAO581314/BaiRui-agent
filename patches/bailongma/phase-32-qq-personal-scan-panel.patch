diff --git a/src/api.js b/src/api.js
--- a/src/api.js
+++ b/src/api.js
@@
+    // GET /social/qq-personal/qr - placeholder for a future personal QQ scan bridge
+    if (req.method === 'GET' && url.pathname === '/social/qq-personal/qr') {
+      if (!hasAllowedAccess(req, url)) return jsonResponse(res, 403, { ok: false, error: 'forbidden' })
+      return jsonResponse(res, 200, {
+        ok: true,
+        status: 'bridge_missing',
+        bridge: 'qq-personal',
+        provider: 'planned',
+        message: 'QQ personal scan bridge is not installed yet. Install NapCat or Lagrange bridge before QR login.',
+      })
+    }
+
+    // POST /social/qq-personal/start - planned connector entry, kept explicit
+    if (req.method === 'POST' && url.pathname === '/social/qq-personal/start') {
+      if (!requireLocalOrToken(req, res, url)) return
+      emitEvent('social_status', { platform: 'qq-personal', status: 'bridge_missing' })
+      return jsonResponse(res, 501, {
+        ok: false,
+        error: 'qq_personal_bridge_missing',
+        status: 'bridge_missing',
+        message: 'QQ personal scan bridge is not installed yet.',
+      })
+    }
+
+    // POST /social/qq-personal/logout - planned disconnect entry, harmless today
+    if (req.method === 'POST' && url.pathname === '/social/qq-personal/logout') {
+      if (!requireLocalOrToken(req, res, url)) return
+      emitEvent('social_status', { platform: 'qq-personal', status: 'idle' })
+      return jsonResponse(res, 200, { ok: true, status: 'idle' })
+    }
