diff -ruN /dev/null src/moxi-runtime-bridge.js
--- /dev/null	2026-06-04 08:13:42.237356473 +0000
+++ src/moxi-runtime-bridge.js	2026-06-08 18:15:25.491068014 +0000
@@ -0,0 +1,47 @@
+const DEFAULT_TIMEOUT_MS = 1800
+
+function getHermesRuntimeConfig() {
+  const baseURL = String(process.env.HERMES_RUNTIME_BASE_URL || process.env.MOXI_RUNTIME_BASE_URL || '').trim()
+  const user = String(process.env.HERMES_RUNTIME_BASIC_USER || process.env.MOXI_RUNTIME_BASIC_USER || '').trim()
+  const password = String(process.env.HERMES_RUNTIME_BASIC_PASSWORD || process.env.MOXI_RUNTIME_BASIC_PASSWORD || '').trim()
+  return { baseURL: baseURL.replace(/\/$/, ''), user, password }
+}
+
+function hermesRuntimeHeaders(runtime, contentType = '') {
+  const headers = { accept: 'application/json' }
+  if (contentType) headers['content-type'] = contentType
+  if (runtime.user || runtime.password) {
+    headers.authorization = `Basic ${Buffer.from(`${runtime.user}:${runtime.password}`).toString('base64')}`
+  }
+  return headers
+}
+
+export async function postHermesRuntimeJson(pathname, body, { timeoutMs = DEFAULT_TIMEOUT_MS } = {}) {
+  const runtime = getHermesRuntimeConfig()
+  if (!runtime.baseURL) return { ok: false, reason: 'missing_runtime_base_url' }
+  const controller = new AbortController()
+  const timer = setTimeout(() => controller.abort(), timeoutMs)
+  try {
+    const resp = await fetch(`${runtime.baseURL}${pathname}`, {
+      method: 'POST',
+      headers: hermesRuntimeHeaders(runtime, 'application/json'),
+      body: JSON.stringify(body || {}),
+      signal: controller.signal,
+    })
+    const payload = await resp.json().catch(() => ({}))
+    if (!resp.ok) return { ok: false, reason: `http_${resp.status}`, payload }
+    return { ok: true, payload }
+  } catch (err) {
+    return { ok: false, reason: err?.name === 'AbortError' ? 'timeout' : (err?.message || 'request_failed') }
+  } finally {
+    clearTimeout(timer)
+  }
+}
+
+export async function reportHermesJobEvent(jobId, event, { resultPointer = '', errorMessage = '', timeoutMs = DEFAULT_TIMEOUT_MS } = {}) {
+  if (!jobId || !event) return { ok: false, reason: 'missing_job_event' }
+  const body = { job_id: String(jobId), event: String(event) }
+  if (resultPointer) body.result_pointer = String(resultPointer).slice(0, 240)
+  if (errorMessage) body.error_message = String(errorMessage).slice(0, 240)
+  return await postHermesRuntimeJson('/jobs/event', body, { timeoutMs })
+}
