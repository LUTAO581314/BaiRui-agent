+function emitHermesQuickAck(plan, { fromId, channel }) {
+  const ack = plan?.ack
+  const text = String(ack?.text || '').trim()
+  if (!ack?.should_send || !text) return false
+  const route = plan?.route?.route || 'unknown'
+  emitEvent('message', {
+    from: 'consciousness',
+    to: fromId,
+    content: text,
+    timestamp: new Date().toISOString(),
+    channel: channel || 'API',
+    moxi_progress: true,
+    route,
+    job_id: plan?.job?.job_id || plan?.active_job?.job_id || '',
+  })
+  emitEvent('moxi_progress', {
+    status: 'ack_sent',
+    route,
+    first_action: plan?.first_action || '',
+    job_id: plan?.job?.job_id || plan?.active_job?.job_id || '',
+    timestamp: new Date().toISOString(),
+  })
+  if (plan?.job?.job_id && ack.next_job_status_after_send) {
+    reportHermesJobEvent(plan.job.job_id, 'ack_sent')
+  }
+  return true
+}
