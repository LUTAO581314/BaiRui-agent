+function normalizeHermesChannel(channel) {
+  const text = String(channel || '').trim().toLowerCase()
+  if (text.includes('wechat')) return 'wechat'
+  if (text.includes('feishu') || text.includes('lark')) return 'feishu'
+  if (text.includes('qq')) return 'qq'
+  if (text.includes('web')) return 'web'
+  return 'web'
+}
+
+async function planHermesSocialTurn({ channel, targetId, message }) {
+  const result = await postHermesRuntimeJson('/social/turn', {
+    channel: normalizeHermesChannel(channel),
+    target_id: String(targetId || 'web:brain-ui'),
+    message: String(message || ''),
+  })
+  if (!result.ok || result.payload?.status !== 'ok') return null
+  return result.payload
+}
