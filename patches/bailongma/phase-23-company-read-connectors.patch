+export const companySchemas = {
+  feishu_lookup_user: {
+    type: 'function',
+    function: {
+      name: 'feishu_lookup_user',
+      description: 'Read-only Feishu company identity lookup. Use for Feishu sender/profile questions. Never use it for writes or approvals. Returns sanitized identity metadata only.',
+      parameters: {
+        type: 'object',
+        properties: {
+          user_id: { type: 'string', description: 'Feishu user id value. Usually open_id from the current Feishu sender context.' },
+          user_id_type: { type: 'string', enum: ['open_id', 'user_id', 'union_id'], description: 'Identifier type. Default open_id.' },
+        },
+        required: ['user_id'],
+      },
+    },
+  },
+  feishu_bitable_list_records: {
+    type: 'function',
+    function: {
+      name: 'feishu_bitable_list_records',
+      description: 'Read-only Feishu Bitable record listing for company/project/task tables. Uses configured FEISHU_BITABLE_APP_TOKEN and FEISHU_BITABLE_TABLE_ID when app_token/table_id are omitted. Never writes records.',
+      parameters: {
+        type: 'object',
+        properties: {
+          app_token: { type: 'string', description: 'Optional Bitable app token. Prefer server env defaults unless the owner provided a specific token.' },
+          table_id: { type: 'string', description: 'Optional Bitable table id. Prefer server env defaults unless the owner provided a specific table.' },
+          view_id: { type: 'string', description: 'Optional Feishu Bitable view id.' },
+          page_size: { type: 'number', description: 'Records to return, default 20, max 50.' },
+          page_token: { type: 'string', description: 'Optional pagination token from a previous response.' },
+          field_names: { type: 'array', items: { type: 'string' }, description: 'Optional field names to include.' },
+        },
+      },
+    },
+  },
+}

