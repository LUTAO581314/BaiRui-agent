diff -ruN /dev/null src/social/feishu-openapi.js
--- /dev/null	2026-06-04 08:13:42.237356473 +0000
+++ src/social/feishu-openapi.js	2026-06-08 18:43:28.933036041 +0000
@@ -0,0 +1,150 @@
+import { requestJson } from './http.js'
+import { env } from './utils.js'
+
+let tenantToken = null
+let tenantTokenExpiresAt = 0
+let tenantTokenRefreshing = null
+
+function cleanText(value, max = 500) {
+  return String(value ?? '').trim().slice(0, max)
+}
+
+function cleanId(value, max = 160) {
+  return cleanText(value, max).replace(/[^A-Za-z0-9_\-:.]/g, '')
+}
+
+function cleanUser(user = {}) {
+  return {
+    union_id: cleanId(user.union_id || ''),
+    user_id: cleanId(user.user_id || ''),
+    open_id: cleanId(user.open_id || ''),
+    name: cleanText(user.name || user.en_name || ''),
+    department_ids: Array.isArray(user.department_ids) ? user.department_ids.map(id => cleanId(id)).filter(Boolean).slice(0, 20) : [],
+    email_present: Boolean(user.email),
+    mobile_present: Boolean(user.mobile),
+    status: user.status || null,
+  }
+}
+
+function cleanRecord(record = {}) {
+  const fields = record.fields && typeof record.fields === 'object' ? record.fields : {}
+  const safeFields = {}
+  for (const [key, value] of Object.entries(fields).slice(0, 30)) {
+    if (typeof value === 'string') safeFields[key] = cleanText(value, 500)
+    else if (typeof value === 'number' || typeof value === 'boolean') safeFields[key] = value
+    else if (Array.isArray(value)) safeFields[key] = value.slice(0, 8).map(item => typeof item === 'object' ? '[object]' : cleanText(item, 120))
+    else if (value && typeof value === 'object') safeFields[key] = '[object]'
+    else safeFields[key] = value ?? null
+  }
+  return {
+    record_id: cleanId(record.record_id || ''),
+    created_time: record.created_time || null,
+    last_modified_time: record.last_modified_time || null,
+    fields: safeFields,
+  }
+}
+
+export async function getFeishuTenantToken() {
+  const appId = env('FEISHU_APP_ID')
+  const appSecret = env('FEISHU_APP_SECRET')
+  if (!appId || !appSecret) throw new Error('FEISHU_APP_ID/FEISHU_APP_SECRET not configured')
+  if (tenantToken && Date.now() < tenantTokenExpiresAt) return tenantToken
+  if (tenantTokenRefreshing) return tenantTokenRefreshing
+  tenantTokenRefreshing = (async () => {
+    try {
+      const res = await requestJson('https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal', {
+        method: 'POST',
+        body: { app_id: appId, app_secret: appSecret },
+        timeoutMs: 10000,
+      })
+      if (!res.ok || res.data?.code !== 0) throw new Error(`Feishu token failed: ${res.text}`)
+      tenantToken = res.data.tenant_access_token
+      tenantTokenExpiresAt = Date.now() + Math.max(60, Number(res.data.expire || 7200) - 120) * 1000
+      return tenantToken
+    } finally {
+      tenantTokenRefreshing = null
+    }
+  })()
+  return tenantTokenRefreshing
+}
+
+async function feishuGet(pathname, query = {}) {
+  const token = await getFeishuTenantToken()
+  const url = new URL(`https://open.feishu.cn/open-apis${pathname}`)
+  for (const [key, value] of Object.entries(query || {})) {
+    if (value !== undefined && value !== null && String(value).trim() !== '') url.searchParams.set(key, String(value))
+  }
+  const res = await requestJson(url.toString(), {
+    headers: { Authorization: `Bearer ${token}` },
+    timeoutMs: 12000,
+  })
+  if (!res.ok || res.data?.code !== 0) {
+    const code = res.data?.code ?? res.status
+    const msg = res.data?.msg || res.text || 'request failed'
+    throw new Error(`Feishu OpenAPI read failed (${code}): ${msg}`)
+  }
+  return res.data?.data || {}
+}
+
+export function getFeishuReadiness() {
+  return {
+    ok: true,
+    configured: Boolean(env('FEISHU_APP_ID') && env('FEISHU_APP_SECRET')),
+    read_only: true,
+    tools: {
+      user_lookup: { state: 'ready_if_permission_granted', permission: 'contact:user:readonly or equivalent contact read scope' },
+      bitable_records: { state: env('FEISHU_BITABLE_APP_TOKEN') && env('FEISHU_BITABLE_TABLE_ID') ? 'configured' : 'missing_table_config', env: ['FEISHU_BITABLE_APP_TOKEN', 'FEISHU_BITABLE_TABLE_ID'] },
+      drive_docs_search: { state: 'planned', reason: 'add after confirming Drive/Search scopes for the tenant' },
+    },
+    secret_policy: 'returns configuration booleans and metadata only; never returns app secrets or tenant tokens',
+  }
+}
+
+export async function lookupFeishuUser({ user_id, user_id_type = 'open_id' } = {}) {
+  const id = cleanId(user_id)
+  const type = ['open_id', 'user_id', 'union_id'].includes(user_id_type) ? user_id_type : 'open_id'
+  if (!id) return { ok: false, tool: 'feishu_lookup_user', error: 'user_id required' }
+  try {
+    const data = await feishuGet(`/contact/v3/users/${encodeURIComponent(id)}`, { user_id_type: type })
+    return {
+      ok: true,
+      tool: 'feishu_lookup_user',
+      user_id_type: type,
+      user: cleanUser(data.user || data),
+      source: 'feishu.contact.v3.users.get',
+      privacy: 'email/mobile are returned as presence booleans only',
+    }
+  } catch (err) {
+    return { ok: false, tool: 'feishu_lookup_user', error: cleanText(err.message, 300), permission_hint: 'Grant contact/user read permission and publish the Feishu app version.' }
+  }
+}
+
+export async function listFeishuBitableRecords({ app_token, table_id, view_id = '', page_size = 20, page_token = '', field_names = [] } = {}) {
+  const appToken = cleanId(app_token || env('FEISHU_BITABLE_APP_TOKEN'))
+  const tableId = cleanId(table_id || env('FEISHU_BITABLE_TABLE_ID'))
+  if (!appToken || !tableId) {
+    return { ok: false, tool: 'feishu_bitable_list_records', error: 'app_token/table_id required or FEISHU_BITABLE_APP_TOKEN/FEISHU_BITABLE_TABLE_ID must be configured' }
+  }
+  const safePageSize = Math.max(1, Math.min(Number(page_size || 20), 50))
+  const query = { page_size: safePageSize }
+  if (view_id) query.view_id = cleanId(view_id)
+  if (page_token) query.page_token = cleanId(page_token)
+  if (Array.isArray(field_names) && field_names.length) query.field_names = JSON.stringify(field_names.slice(0, 20).map(name => cleanText(name, 80)))
+  try {
+    const data = await feishuGet(`/bitable/v1/apps/${encodeURIComponent(appToken)}/tables/${encodeURIComponent(tableId)}/records`, query)
+    const items = Array.isArray(data.items) ? data.items : []
+    return {
+      ok: true,
+      tool: 'feishu_bitable_list_records',
+      app_token_configured: Boolean(appToken),
+      table_id: tableId,
+      has_more: Boolean(data.has_more),
+      page_token: cleanText(data.page_token || '', 200),
+      records: items.map(cleanRecord),
+      source: 'feishu.bitable.v1.records.list',
+      privacy: 'record fields are truncated and object attachments are summarized',
+    }
+  } catch (err) {
+    return { ok: false, tool: 'feishu_bitable_list_records', error: cleanText(err.message, 300), permission_hint: 'Grant Bitable read permission and ensure the app has access to this base/table.' }
+  }
+}

